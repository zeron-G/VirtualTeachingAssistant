# EditorConfig is awesome: https://EditorConfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Do not trim trailing whitespace in Markdown (two trailing spaces = hard break).
[*.md]
trim_trailing_whitespace = false
