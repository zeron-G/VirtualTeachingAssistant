{
  "name": "@vta/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Virtual Teaching Assistant — a governed, multi-tenant course assistant built on the Pi agent harness.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rimraf node_modules/.cache .turbo",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:generate": "pnpm --filter @vta/data db:generate",
    "db:push": "pnpm --filter @vta/data db:push",
    "db:migrate": "pnpm --filter @vta/data db:migrate",
    "db:studio": "pnpm --filter @vta/data db:studio",
    "db:indexes": "pnpm --filter @vta/data db:indexes",
    "eval": "tsx evals/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "zod": "^3.24.1"
  }
}
